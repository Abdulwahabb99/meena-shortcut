# Base URL for payment APIs (no trailing slash). Path /Moyasar is appended in code.
# Example: https://payment.meena-health.com/api
#
# Optional: if unset, the app uses the same default URL (works on Vercel without env).
# To use another URL (staging, etc.), set this in .env locally and in Vercel → Settings → Environment Variables, then redeploy.
REACT_APP_PAYMENT_API_BASE=
